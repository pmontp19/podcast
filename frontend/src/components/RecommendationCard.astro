---
interface Props {
  obra: string;
  categoria: string;
  marca_temps: string;
  context: string;
  imatge_url?: string;
  autor?: string;
  any?: string | number;
  puntuacio?: number;
  episodi: {
    id: string;
    titol: string;
    audio_url: string;
  };
}

const { obra, categoria, marca_temps, context, imatge_url, autor, any: any_val, puntuacio, episodi } = Astro.props;

const badgeColors: Record<string, string> = {
  pelicula: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300',
  serie: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
  podcast: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
  llibre: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
  videojoc: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300',
  altres: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300',
};

const categoryLabels: Record<string, string> = {
  pelicula: "Pel·lícula",
  serie: 'Sèrie',
  podcast: 'Podcast',
  llibre: 'Llibre',
  videojoc: 'Videojoc',
  altres: 'Altres',
};

const badgeClass = badgeColors[categoria] ?? badgeColors.altres;
const categoryLabel = categoryLabels[categoria] ?? categoria;

const placeholder = 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200"><rect width="200" height="200" fill="%23374151"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="%236b7280" font-size="14">No image</text></svg>';
---

<article
  class="recommendation-card bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden flex flex-col hover:shadow-lg transition-shadow"
  data-obra={obra.toLowerCase()}
  data-autor={(autor ?? '').toLowerCase()}
  data-context={context.toLowerCase()}
  data-categoria={categoria}
  data-episodi-id={episodi.id}
>
  <!-- Cover image -->
  <div class="relative aspect-square overflow-hidden bg-gray-100 dark:bg-gray-800">
    <img
      src={imatge_url || placeholder}
      alt={obra}
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22 viewBox=%220 0 200 200%22><rect width=%22200%22 height=%22200%22 fill=%22%23374151%22/></svg>'"
    />
    <span class={`absolute top-2 left-2 px-2 py-0.5 rounded-full text-xs font-semibold ${badgeClass}`}>
      {categoryLabel}
    </span>
    {puntuacio && (
      <span class="absolute top-2 right-2 bg-black/60 text-white text-xs px-2 py-0.5 rounded-full flex items-center gap-1">
        <svg class="w-3 h-3 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {puntuacio.toFixed(1)}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="flex-1 flex flex-col p-4 gap-2">
    <h3 class="font-semibold text-base leading-tight">{obra}</h3>
    {(autor || any_val) && (
      <p class="text-sm text-gray-500 dark:text-gray-400">
        {autor}{autor && any_val ? ' · ' : ''}{any_val}
      </p>
    )}
    <blockquote class="text-sm text-gray-600 dark:text-gray-400 italic line-clamp-3 flex-1 border-l-2 border-orange-300 pl-2">
      "{context}"
    </blockquote>
    <p class="text-xs text-gray-400 dark:text-gray-500 truncate" title={episodi.titol}>
      {episodi.titol}
    </p>
  </div>

  <!-- Play button -->
  <div class="px-4 pb-4">
    <button
      class="play-context-btn w-full flex items-center justify-center gap-2 py-2 px-4 rounded-lg bg-orange-500 hover:bg-orange-600 text-white text-sm font-medium transition-colors"
      data-audio-url={episodi.audio_url}
      data-timestamp={marca_temps}
      data-obra={obra}
      data-episodi-titol={episodi.titol}
      data-imatge={imatge_url || ''}
    >
      <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      Escoltar context
    </button>
  </div>
</article>
