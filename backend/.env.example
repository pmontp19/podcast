# Claus API (obligatòries)
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...

# TMDB (opcional — per enriquir pel·lícules i sèries)
TMDB_API_KEY=

# URL del feed RSS del podcast (obligatòria per transcriure/tot)
RSS_URL=https://example.com/feed.xml

# Ruta a la base de dades SQLite
DB_PATH=dades/podcast.db

# Model Groq per transcripció
GROQ_MODEL=whisper-large-v3

# Model Anthropic per extracció d'entitats
ANTHROPIC_MODEL=claude-haiku-4-5

# Nombre màxim d'episodis a processar per execució
MAX_EPISODIS=10

# Nivell de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
