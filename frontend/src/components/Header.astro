---
interface Props {
  titol: string;
  autor: string;
  descripcio: string;
  imatge_url: string;
}
const { titol, autor, descripcio, imatge_url } = Astro.props;
---

<header class="border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 sticky top-0 z-40 backdrop-blur-sm bg-white/90 dark:bg-gray-900/90">
  <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
    <img
      src={imatge_url}
      alt={titol}
      width="80"
      height="80"
      class="rounded-xl shadow-md flex-shrink-0"
    />
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-orange-500 tracking-tight">{titol}</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">{descripcio}</p>
    </div>
    <button
      id="dark-toggle"
      class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-300 flex-shrink-0"
      aria-label="Canviar tema"
    >
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
        <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('dark-toggle');
  btn?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
